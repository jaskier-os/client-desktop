# Copy this file to .env and adjust values. The .env file is gitignored.
# All settings have safe plain-connection defaults; only ORCHESTRATOR_WS_URL
# typically needs changing.

# Orchestrator WebSocket endpoint the client connects to.
# Use ws:// for a plain connection, wss:// to enable TLS.
ORCHESTRATOR_WS_URL=ws://localhost:10001/ws/device

# Logical device identifier reported to the orchestrator.
DEVICE_ID=desktop-listener

# Default model the orchestrator routes requests to (e.g. sonnet, opus, haiku).
ORCHESTRATOR_MODEL=sonnet

# OPTIONAL TLS certificate (CA/PEM) used only for wss:// connections.
# Leave empty to use the system trust store (public certs) or a plain ws://
# connection. If set but the file does not exist, the client falls back safely
# instead of crashing. Self-signed/VPN certificates are entirely optional.
TLS_CERT_PATH=

# OPTIONAL WebRTC TURN relay for desktop audio/screen streaming.
# Leave TURN_URL empty to use STUN-only (public Google STUN), which works for
# most direct/NAT scenarios. Set a TURN server when peers cannot connect
# directly. Username/credential are optional.
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=

# OPTIONAL override for the public STUN server.
STUN_URL=stun:stun.l.google.com:19302

# LAN-direct audio relay. When the phone is on the same network it connects its
# audio-relay signaling straight to this desktop (a small local WebSocket server
# advertised over mDNS), skipping the cloud orchestrator hop. Leave enabled;
# set LOCAL_RELAY_ENABLED=false to force all audio through the cloud path.
LOCAL_RELAY_ENABLED=true
LOCAL_RELAY_PORT=10101
