[wake_word]
keywords = hello
cancel_keywords = cancel, отмена, отменить, отмени
vosk_model_en = models/vosk-model-small-en-us-0.15
vosk_model_ru = models/vosk-model-small-ru-0.22
enable_rms_gate = true
rms_threshold = 0.02
confidence_threshold = 0.6
use_word_boundaries = true

[transcription]
model = large-v3
device = cuda
compute_type = float16

[vad]
silence_threshold_ms = 1500
max_recording_seconds = 30.0
probability_threshold = 0.65

[speaker]
enabled = true
threshold = 0.45
profile_path = models/voice_profile.npy

[orchestrator]
api_url = http://localhost:10001
ws_url = ws://localhost:10001/ws/device
api_key = YOUR_API_KEY_HERE
model = sonnet
